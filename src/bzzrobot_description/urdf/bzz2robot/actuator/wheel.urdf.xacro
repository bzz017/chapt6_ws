<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="wheel_actuator" params="parent link_name joint_name *origin">

    <link name="${link_name}">
    <!-- 轮子可视化 -->
      <visual>
        <origin xyz="0 0 0" rpy="1.57079 0 0" />
        <geometry>
          <cylinder radius="0.032" length="0.05" />
        </geometry>
        <material name="${link_name}_material">
          <color rgba="1.0 0.84 0.0 0.9" />
        </material>
      </visual>
       <!-- wheel 碰撞体 -->
      <collision>
        <origin xyz="0 0 0" rpy="1.57079 0 0" />
        <geometry>
          <cylinder radius="0.032" length="0.05" />
        </geometry>
        <material name="${link_name}_material">
          <color rgba="1.0 0.84 0.0 0.9" />
        </material>
      </collision>
      <!-- wheel 惯性设置 -->
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="0.5" />
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005" />
      </inertial>
    </link>

    <joint name="${joint_name}" type="continuous">
      <parent link="${parent}" />
      <child link="${link_name}" />
      <xacro:insert_block name="origin" />
      <!-- 定义轮子绕Y轴旋转 -->
      <axis xyz="0 1 0" />
    </joint>

    <!-- Gazebo 摩擦系数设置：防止轮子打滑 -->
    <gazebo reference="${link_name}">
      <mu1>20.0</mu1>           <!-- 静摩擦系数（沿第一个切线方向） -->
      <mu2>20.0</mu2>           <!-- 动摩擦系数（沿第二个切线方向） -->
      <kp>1000000.0</kp>       <!-- 接触刚度，越大越硬 -->
      <kd>1.0</kd>             <!-- 接触阻尼 -->
      <minDepth>0.001</minDepth>
      <material>Gazebo/Yellow</material>
    </gazebo>

  </xacro:macro>

</robot>
